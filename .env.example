# OpenAI API Key for tunnel-client
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file containing your API key to version control!
OPENAI_API_KEY=your-openai-api-key-here

# Allowed directories for bifrost file tools (separated by ';' on Windows, ':' on Unix, or ',' on any platform)
# If empty or not set, read_file and list_dir tools are disabled.
BIFROST_ALLOWED_DIRS=
